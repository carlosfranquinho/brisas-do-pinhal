def to_float(d: dict, key: str):
    try:
        v = d.get(key)
        if v is None:
            return None
        s = str(v).strip()
        if s in ("", "NA", "nan", "NaN"):
            return None
        return float(s)
    except Exception:
        return None

def dewpoint_from_temp_rh(t_c: float, rh_pct: float):
    if t_c is None or rh_pct is None or rh_pct <= 0:
        return None
    a, b = 17.62, 243.12
    gamma = (a * t_c) / (b + t_c) + math.log(rh_pct / 100.0)
    return round((b * gamma) / (a - gamma), 1)

def rh_from_temp_vpd(t_c: float, vpd_kpa: float):
    if t_c is None or vpd_kpa is None:
        return None
    es = 0.6108 * math.exp(17.27 * t_c / (t_c + 237.3))
    avp = es - vpd_kpa
    if avp <= 0:
        return 0.0
    rh = (avp / es) * 100.0
    return max(0.0, min(100.0, rh))


