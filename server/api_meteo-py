@app.get("/history/years")
def history_years():
    conn = get_db()
    try:
        cur = conn.cursor()
        cur.execute("""
            SELECT
                CAST(strftime('%Y', ts_local) AS INTEGER) AS year,
                COUNT(DISTINCT substr(ts_local, 1, 10))            AS days_with_data,
                COUNT(DISTINCT strftime('%m', ts_local))  AS months_with_data,
                ROUND(MIN(temp_c), 1) AS temp_min,
                ROUND(MAX(temp_c), 1) AS temp_max,
                ROUND(AVG(temp_c), 1) AS temp_avg,
                ROUND(MAX(gust_kmh), 1) AS gust_max
            FROM observations
            WHERE temp_c IS NOT NULL
            GROUP BY year
            ORDER BY year DESC
        """)
        rows = [dict(r) for r in cur.fetchall()]

        # Chuva anual total: soma do máximo diário de rain_day_mm por dia
        cur.execute("""
            SELECT
                year,
                ROUND(SUM(max_day), 1) AS rain_total
            FROM (
                SELECT CAST(strftime('%Y', ts_local) AS INTEGER) AS year,
                       MAX(rain_day_mm) AS max_day
                FROM observations
                WHERE rain_day_mm IS NOT NULL
                GROUP BY substr(ts_local, 1, 10)
            )
            GROUP BY year
        """)
        rain_by_year = {r["year"]: r["rain_total"] for r in cur.fetchall()}

        for row in rows:
            row["rain_total"] = rain_by_year.get(row["year"])
    finally:
        conn.close()
    return rows


@app.get("/history/analysis/temperature")
def analysis_temperature():
    conn = get_db()
    try:
        cur = conn.cursor()
        cur.execute("""
            SELECT
                CAST(strftime('%Y', ts_local) AS INTEGER) AS year,
                CAST(strftime('%m', ts_local) AS INTEGER) AS month,
                ROUND(AVG(temp_c), 1) AS avg_temp,
                ROUND(MAX(temp_c), 1) AS max_temp,
                ROUND(MIN(temp_c), 1) AS min_temp
            FROM observations
            WHERE temp_c IS NOT NULL
            GROUP BY year, month
            ORDER BY year, month
        """)
        by_year_month = [dict(r) for r in cur.fetchall()]

        cur.execute("""
            SELECT substr(ts_local, 1, 10) AS date, ROUND(MAX(temp_c), 1) AS value
            FROM observations WHERE temp_c IS NOT NULL
            GROUP BY substr(ts_local, 1, 10) ORDER BY value DESC LIMIT 10
        """)
        top_max = [dict(r) for r in cur.fetchall()]

        cur.execute("""
            SELECT substr(ts_local, 1, 10) AS date, ROUND(MIN(temp_c), 1) AS value
            FROM observations WHERE temp_c IS NOT NULL
            GROUP BY substr(ts_local, 1, 10) ORDER BY value ASC LIMIT 10
        """)
        top_min = [dict(r) for r in cur.fetchall()]

        cur.execute("""
            SELECT substr(ts_local, 1, 10) AS date,
                   ROUND((MAX(temp_c) + MIN(temp_c)) / 2.0, 1) AS value
            FROM observations WHERE temp_c IS NOT NULL
            GROUP BY substr(ts_local, 1, 10)
            HAVING MAX(temp_c) IS NOT NULL AND MIN(temp_c) IS NOT NULL
            ORDER BY value DESC LIMIT 10
        """)
        top_warm_days = [dict(r) for r in cur.fetchall()]

        cur.execute("""
            SELECT substr(ts_local, 1, 10) AS date,
                   ROUND((MAX(temp_c) + MIN(temp_c)) / 2.0, 1) AS value
            FROM observations WHERE temp_c IS NOT NULL
            GROUP BY substr(ts_local, 1, 10)
            HAVING MAX(temp_c) IS NOT NULL AND MIN(temp_c) IS NOT NULL
            ORDER BY value ASC LIMIT 10
        """)
        top_cold_days = [dict(r) for r in cur.fetchall()]

        # Ondas de calor: ≥3 dias consecutivos com Tmax ≥ 35 °C
        cur.execute("""
            SELECT substr(ts_local, 1, 10) AS date,
                   ROUND(MAX(temp_c), 1) AS tmax
            FROM observations
            WHERE temp_c IS NOT NULL
            GROUP BY substr(ts_local, 1, 10)
            ORDER BY date
        """)
        daily_tmax = [(r["date"], r["tmax"]) for r in cur.fetchall()]

        HEAT_THRESHOLD = 35.0
        heat_waves = _find_streaks(
            daily_tmax,
            lambda v: v is not None and v >= HEAT_THRESHOLD,
            extra_agg=lambda vs: round(max(vs), 1),
            min_len=3,
        )
        for s in heat_waves:
            if "extra" in s:
                s["peak_tmax"] = s.pop("extra")
    finally:
        conn.close()
    return {
        "by_year_month": by_year_month,
        "top_max": top_max, "top_min": top_min,
        "top_warm_days": top_warm_days, "top_cold_days": top_cold_days,
        "heat_waves": heat_waves,
    }


@app.get("/history/analysis/precipitation")
def analysis_precipitation():
    conn = get_db()
    try:
        cur = conn.cursor()
        cur.execute("""
            SELECT year, month, ROUND(SUM(max_day), 1) AS total
            FROM (
                SELECT
                    CAST(strftime('%Y', ts_local) AS INTEGER) AS year,
                    CAST(strftime('%m', ts_local) AS INTEGER) AS month,
                    MAX(rain_day_mm) AS max_day
                FROM observations
                WHERE rain_day_mm IS NOT NULL
                GROUP BY substr(ts_local, 1, 10)
            )
            GROUP BY year, month ORDER BY year, month
        """)
        by_year_month = [dict(r) for r in cur.fetchall()]

        cur.execute("""
            SELECT substr(ts_local, 1, 10) AS date, ROUND(MAX(rain_day_mm), 1) AS value
            FROM observations WHERE rain_day_mm IS NOT NULL
            GROUP BY substr(ts_local, 1, 10) ORDER BY value DESC LIMIT 10
        """)
        top_rain = [dict(r) for r in cur.fetchall()]

        # Anos mais chuvosos (total anual)
        cur.execute("""
            SELECT year, ROUND(SUM(max_day), 1) AS total
            FROM (
                SELECT CAST(strftime('%Y', ts_local) AS INTEGER) AS year,
                       MAX(rain_day_mm) AS max_day
                FROM observations WHERE rain_day_mm IS NOT NULL
                GROUP BY substr(ts_local, 1, 10)
            )
            GROUP BY year ORDER BY total DESC LIMIT 10
        """)
        top_years = [dict(r) for r in cur.fetchall()]

        # Top 10 meses mais chuvosos
        cur.execute("""
            SELECT year, month, ROUND(SUM(max_day), 1) AS total
            FROM (
                SELECT
                    CAST(strftime('%Y', ts_local) AS INTEGER) AS year,
                    CAST(strftime('%m', ts_local) AS INTEGER) AS month,
                    MAX(rain_day_mm) AS max_day
                FROM observations
                WHERE rain_day_mm IS NOT NULL
                GROUP BY substr(ts_local, 1, 10)
            )
            GROUP BY year, month ORDER BY total DESC LIMIT 10
        """)
        top_months = [dict(r) for r in cur.fetchall()]

        # Top 10 intensidades de precipitação (rain rate mm/h)
        cur.execute("""
            SELECT ts_local AS date, ROUND(rain_rate_mmph, 1) AS value
            FROM observations
            WHERE rain_rate_mmph IS NOT NULL AND rain_rate_mmph > 0
            ORDER BY rain_rate_mmph DESC LIMIT 10
        """)
        top_rate = [dict(r) for r in cur.fetchall()]

        # Streaks: dias consecutivos secos / chuvosos
        cur.execute("""
            SELECT substr(ts_local, 1, 10) AS date,
                   ROUND(MAX(rain_day_mm), 1) AS rain
            FROM observations
            WHERE rain_day_mm IS NOT NULL
            GROUP BY substr(ts_local, 1, 10)
            ORDER BY date
        """)
        daily_rain = [(r["date"], r["rain"] or 0.0) for r in cur.fetchall()]

        DRY_THRESHOLD  = 1.0  # mm — limiar dia seco (norma OMM)
        WET_THRESHOLD  = 1.0  # mm — limiar dia chuvoso
        dry_streaks = _find_streaks(daily_rain, lambda v: v < DRY_THRESHOLD)
        wet_streaks = _find_streaks(daily_rain, lambda v: v >= WET_THRESHOLD,
                                    extra_agg=lambda vs: round(sum(vs), 1))
        # renomear "extra" → "total_mm" para wet_streaks
        for s in wet_streaks:
            if "extra" in s:
                s["total_mm"] = s.pop("extra")
    finally:
        conn.close()
    return {
        "by_year_month": by_year_month,
        "top_rain": top_rain,
        "top_years": top_years,
        "top_months": top_months,
        "top_rate": top_rate,
        "dry_streaks": dry_streaks,
        "wet_streaks": wet_streaks,
    }


@app.get("/history/year/{year}")
def history_year(year: int):
    conn = get_db()
    try:
        cur = conn.cursor()
        yr = str(year)

        # Resumo anual
        cur.execute("""
            SELECT
                ROUND(MIN(temp_c), 1) AS temp_min,
                ROUND(MAX(temp_c), 1) AS temp_max,
                ROUND(AVG(temp_c), 1) AS temp_avg,
                ROUND(MAX(gust_kmh), 1) AS gust_max,
                COUNT(DISTINCT substr(ts_local, 1, 10)) AS days_with_data
            FROM observations
            WHERE strftime('%Y', ts_local) = ? AND temp_c IS NOT NULL
        """, (yr,))
        summary = dict(cur.fetchone() or {})

        cur.execute("""
            SELECT ROUND(SUM(max_day), 1) AS rain_total
            FROM (
                SELECT substr(ts_local, 1, 10) AS d, MAX(rain_day_mm) AS max_day
                FROM observations
                WHERE strftime('%Y', ts_local) = ? AND rain_day_mm IS NOT NULL
                GROUP BY d
            )
        """, (yr,))
        rr = cur.fetchone()
        summary["rain_total"] = dict(rr)["rain_total"] if rr else None

        # Datas dos extremos
        cur.execute("SELECT substr(ts_local, 1, 10) AS d FROM observations WHERE strftime('%Y', ts_local) = ? AND temp_c IS NOT NULL ORDER BY temp_c DESC LIMIT 1", (yr,))
        r = cur.fetchone(); summary["temp_max_date"] = r["d"] if r else None

        cur.execute("SELECT substr(ts_local, 1, 10) AS d FROM observations WHERE strftime('%Y', ts_local) = ? AND temp_c IS NOT NULL ORDER BY temp_c ASC LIMIT 1", (yr,))
        r = cur.fetchone(); summary["temp_min_date"] = r["d"] if r else None

        cur.execute("SELECT substr(ts_local, 1, 10) AS d FROM observations WHERE strftime('%Y', ts_local) = ? AND gust_kmh IS NOT NULL ORDER BY gust_kmh DESC LIMIT 1", (yr,))
        r = cur.fetchone(); summary["gust_max_date"] = r["d"] if r else None

        # Detalhe mensal — temperatura
        cur.execute("""
            SELECT
                CAST(strftime('%m', ts_local) AS INTEGER) AS month,
                COUNT(DISTINCT substr(ts_local, 1, 10)) AS days_with_data,
                ROUND(MIN(temp_c), 1) AS temp_min,
                ROUND(MAX(temp_c), 1) AS temp_max,
                ROUND(AVG(temp_c), 1) AS temp_avg,
                ROUND(MAX(gust_kmh), 1) AS gust_max
            FROM observations
            WHERE strftime('%Y', ts_local) = ? AND temp_c IS NOT NULL
            GROUP BY month ORDER BY month
        """, (yr,))
        months_raw = {r["month"]: dict(r) for r in cur.fetchall()}

        # Chuva mensal
        cur.execute("""
            SELECT
                month,
                ROUND(SUM(max_day), 1) AS rain_total
            FROM (
                SELECT CAST(strftime('%m', ts_local) AS INTEGER) AS month,
                       MAX(rain_day_mm) AS max_day
                FROM observations
                WHERE strftime('%Y', ts_local) = ? AND rain_day_mm IS NOT NULL
                GROUP BY substr(ts_local, 1, 10)
            )
            GROUP BY month ORDER BY month
        """, (yr,))
        for r in cur.fetchall():
            m = r["month"]
            months_raw.setdefault(m, {"month": m})["rain_total"] = r["rain_total"]

        months = [months_raw.get(m) for m in range(1, 13)]
    finally:
        conn.close()

    if not summary.get("days_with_data"):
        return JSONResponse(status_code=404, content={"error": "Ano sem dados."})
    return {"year": year, "summary": summary, "months": months}


@app.get("/climate/monthly")
def climate_monthly(station: str = "meteomg"):
    conn = get_db()
    try:
        cur = conn.cursor()
        cur.execute("""
            WITH primary_days AS (
              SELECT DISTINCT substr(ts_local, 1, 10) AS day
              FROM observations WHERE station_id = ?
            )
            SELECT
              substr(ts_local, 1, 10)                   AS d,
              CAST(strftime('%Y', ts_local) AS INTEGER) AS y,
              CAST(strftime('%m', ts_local) AS INTEGER) AS m,
              MIN(temp_c)                               AS tmin,
              MAX(temp_c)                               AS tmax,
              AVG(temp_c)                               AS tmean,
              MAX(rain_day_mm)                          AS rain_mm
            FROM observations
            WHERE station_id = ?
               OR substr(ts_local, 1, 10) NOT IN (SELECT day FROM primary_days)
            GROUP BY substr(ts_local, 1, 10)
            ORDER BY d ASC
        """, (station, station))
        daily = [dict(r) for r in cur.fetchall()]
    finally:
        conn.close()

    # Acumuladores por mês
    stats = {m: {
        "days": 0,
        "tmean_sum": 0.0, "tmax_sum": 0.0, "tmin_sum": 0.0,
        "abs_max_val": None, "abs_max_date": None,
        "abs_min_val": None, "abs_min_date": None,
    } for m in range(1, 13)}

    counts_by_year = {m: defaultdict(lambda: {
        "frost": 0, "summer": 0, "tropical": 0, "tnight": 0, "wet": 0
    }) for m in range(1, 13)}
    rain_by_year = {m: defaultdict(float) for m in range(1, 13)}

    for row in daily:
        m = int(row["m"]); y = int(row["y"])
        tmin  = row["tmin"];  tmax = row["tmax"];  tmean = row["tmean"]
        rain  = float(row["rain_mm"] or 0.0)
        d     = row["d"]  # string "YYYY-MM-DD"

        if tmean is not None: stats[m]["tmean_sum"] += float(tmean)
        if tmax  is not None: stats[m]["tmax_sum"]  += float(tmax)
        if tmin  is not None: stats[m]["tmin_sum"]  += float(tmin)
        stats[m]["days"] += 1

        if tmax is not None and (stats[m]["abs_max_val"] is None or tmax > stats[m]["abs_max_val"]):
            stats[m]["abs_max_val"]  = float(tmax)
            stats[m]["abs_max_date"] = d
        if tmin is not None and (stats[m]["abs_min_val"] is None or tmin < stats[m]["abs_min_val"]):
            stats[m]["abs_min_val"]  = float(tmin)
            stats[m]["abs_min_date"] = d

        c = counts_by_year[m][y]
        if tmin is not None and tmin <  0.0: c["frost"]   += 1
        if tmax is not None and tmax > 25.0: c["summer"]  += 1
        if tmax is not None and tmax > 30.0: c["tropical"]+= 1
        if tmin is not None and tmin >=20.0: c["tnight"]  += 1
        if rain > 0.0:                        c["wet"]     += 1

        rain_by_year[m][y] += rain

    def avg_or_none(soma, n):
        return round(soma / n, 1) if n else None

    out = []
    for m in range(1, 13):
        s = stats[m]
        n_days = s["days"]

        t_mean    = avg_or_none(s["tmean_sum"], n_days)
        tmax_mean = avg_or_none(s["tmax_sum"],  n_days)
        tmin_mean = avg_or_none(s["tmin_sum"],  n_days)

        year_counts = counts_by_year[m]
        n_years = len(year_counts)
        def idx_mean(key):
            if not n_years: return None
            return round(sum(v[key] for v in year_counts.values()) / n_years, 1)

        monthly_rains = list(rain_by_year[m].values())
        precip_mean = round(sum(monthly_rains) / len(monthly_rains), 1) if monthly_rains else None

        out.append({
            "month": m,
            "t_mean": t_mean,
            "tmax_mean": tmax_mean,
            "tmin_mean": tmin_mean,
            "frost_days": idx_mean("frost"),
            "summer_days": idx_mean("summer"),
            "tropical_days": idx_mean("tropical"),
            "tropical_nights": idx_mean("tnight"),
            "wet_days": idx_mean("wet"),
            "precip_mean_mm": precip_mean,
            "abs_max": s["abs_max_val"], "abs_max_date": s["abs_max_date"],
            "abs_min": s["abs_min_val"], "abs_min_date": s["abs_min_date"],
        })

    return JSONResponse(
        content={"station": station, "months": out},
        headers={"Cache-Control": "no-store"}
    )
