def f_to_c(f): return round((f - 32) * 5.0 / 9.0, 1)


def _find_streaks(daily_rows, predicate, extra_agg=None, min_len=1, top_n=10):
    """Encontra períodos consecutivos onde predicate(value) é True.
    daily_rows: lista de (date_str "YYYY-MM-DD", value)
    extra_agg: função(values_list) -> extra, para acumular um valor extra durante o período
    Retorna lista de {"start", "end", "days"[, "extra"]} ordenada por dias desc.
    """
    streaks = []
    start = current_end = None
    length = 0
    extras = []
    prev_d = None

    for date_str, value in daily_rows:
        cur_d = datetime.strptime(date_str, "%Y-%m-%d").date()
        # quebra de streak se houver gap nos dados
        if prev_d is not None and (cur_d - prev_d) > timedelta(days=1):
            if start is not None and length >= min_len:
                e = extra_agg(extras) if extra_agg else None
                streaks.append({"start": start, "end": current_end, "days": length,
                                 **({} if e is None else {"extra": e})})
            start = current_end = None
            length = 0
            extras = []

        if predicate(value):
            if start is None:
                start = date_str
            current_end = date_str
            length += 1
            if extra_agg is not None:
                extras.append(value)
        else:
            if start is not None and length >= min_len:
                e = extra_agg(extras) if extra_agg else None
                streaks.append({"start": start, "end": current_end, "days": length,
                                 **({} if e is None else {"extra": e})})
            start = current_end = None
            length = 0
            extras = []
        prev_d = cur_d

    if start is not None and length >= min_len:
        e = extra_agg(extras) if extra_agg else None
        streaks.append({"start": start, "end": current_end, "days": length,
                         **({} if e is None else {"extra": e})})

    streaks.sort(key=lambda x: x["days"], reverse=True)
    return streaks[:top_n]
def mph_to_kmh(mph): return round(mph * 1.60934, 1)
def in_to_mm(inches): return round(inches * 25.4, 2)
def inHg_to_hPa(inhg): return round(inhg * 33.8639, 1)

